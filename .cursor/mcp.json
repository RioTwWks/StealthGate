{
  "mcpServers": {
    "stealth-gate": {
      "command": "cargo",
      "args": [
        "run",
        "--quiet",
        "--bin",
        "stealth-gate-mcp",
        "--",
        "--config",
        "configs/config.toml"
      ],
      "description": "MCP stdio: stats, config, get_proxy_link, reload, update_secret"
    },
    "filesystem": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-filesystem", "."],
      "description": "Доступ к файлам проекта StealthGate"
    },
    "fetch": {
      "command": "npx",
      "args": ["-y", "fetch-mcp"],
      "description": "HTTP-клиент для тестирования WebUI и MCP API"
    }
  }
}
